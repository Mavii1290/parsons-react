
import React, { useState, useCallback, useRef, useEffect } from 'react';
import HeaderBar from "../../HeaderBar/HeaderBar";
import Footer from "../../Footer/Footer";
import ConfirmationModal from '../../common/ConfirmationModal';
import StepNavigation from './StepNavigation';
import Step1DisplaySize from './steps/Step1DisplaySize';
import Step2DesignOptions from './steps/Step2DesignOptions';
import Step3MainCourt from './steps/Step3MainCourt';
import Step4AdditionalCourts from './steps/Step4AdditionalCourts'; 
import Step5Elements from './steps/Step5Elements';
import Step6Review from './steps/Step6Review';
import styles from '../../GymDesigner/GymDesigner.module.css';

// Import gym floor image
import gymFloorImage from '../Assets/gym-floor.jpg';

const GymDesignerPage = () => {
  const canvasRef = useRef(null);
  const [currentStep, setCurrentStep] = useState(1);
  const [showConfirmModal, setShowConfirmModal] = useState(false);
  const [imageLoaded, setImageLoaded] = useState(false);

  // Step 1: Display Size
  const [displaySize, setDisplaySize] = useState({
    type: 'high-school', // 'high-school', 'university', 'custom', 'none'
    width: 100,
    length: 100,
    zoom: 1
  });

  // Step 2: Design Options
  const [designOptions, setDesignOptions] = useState({
    borderSize: 3,
    borderColorTop: '#000000',
    borderColorBottom: '#000000',
    borderColorLeft: '#000000',
    borderColorRight: '#000000',
    lineColor: '#FFFFFF',
    courtInteriorColor: '#D2691E',
    keyColor: '#CD853F',
    // keyArchColor: '#ffffff',
    threePointFillColor: '#ffffff',
    centerCourtLogo: null,
    additionalLogos: [],
    gridLines: true,
    borderFont: 'Arial'
  });

  // Step 3: Main Court
  const [mainCourt, setMainCourt] = useState({
    enabled: true,
    width: 84,
    length: 50,
    type: 'basketball',
    showKey: true,
    showKeyArch: true,
    showThreePoint: true,
    showCenterCircle: true
  });

  // Step 4: Additional Courts
  const [additionalCourts, setAdditionalCourts] = useState({
    sideBasketball: { enabled: false, width: 84, length: 50 },
    volleyball: { enabled: false, width: 59, length: 118 },
    badminton: { enabled: false, width: 44, length: 88 },
    pickleball: { enabled: false, width: 44, length: 88 }
  });

  // Step 5: Elements
  const [elements, setElements] = useState({
    bowlingPinMarkers: { enabled: false, count: 10 },
    baseballBases: { enabled: false },
    numbersAndLetters: { enabled: false, range: '1-24', current: '' },
    agilityLadder: { enabled: false, length: 15 },
    agilityDots: { enabled: false, count: 10 }
  });

  const totalSteps = 6;

  const nextStep = () => {
    if (currentStep < totalSteps) {
      setCurrentStep(currentStep + 1);
    }
  };

  const prevStep = () => {
    if (currentStep > 1) {
      setCurrentStep(currentStep - 1);
    }
  };

  const goToStep = (step) => {
    setCurrentStep(step);
  };

  // FIXED: Drawing function with proper layer order
  const drawCourt = useCallback(() => {
    if (!canvasRef.current) return;
    
    const ctx = canvasRef.current.getContext('2d');
    const { width: canvasWidth, height: canvasHeight } = ctx.canvas;
    
    // Clear canvas completely
    ctx.clearRect(0, 0, canvasWidth, canvasHeight);
    
    // STEP 1: Draw the image background FIRST
    drawImageBackground(ctx, canvasWidth, canvasHeight);
    
    // STEP 2: Apply zoom
    ctx.save();
    ctx.scale(displaySize.zoom, displaySize.zoom);
    
    // STEP 3: Draw court backgrounds/shapes
    if (mainCourt.enabled) {
      drawMainCourtBackground(ctx, canvasWidth, canvasHeight);
    }
    
    // STEP 4: Draw ALL lines ON TOP of backgrounds
    drawAllCourtLines(ctx, canvasWidth, canvasHeight);
    
    // STEP 5: Draw additional elements
    drawElements(ctx, canvasWidth, canvasHeight);
    
    // STEP 6: Draw borders and text
    drawDesignOptions(ctx, canvasWidth, canvasHeight);
    
    ctx.restore();
    
    // STEP 7: Draw grid lines last (on top of everything)
    if (designOptions.gridLines) {
      drawGridLines(ctx, canvasWidth, canvasHeight);
    }
  }, [displaySize, mainCourt, additionalCourts, elements, designOptions, imageLoaded]);

  const drawImageBackground = (ctx, width, height) => {
    const image = new Image();
    image.src = gymFloorImage;
    
    if (image.complete) {
      ctx.drawImage(image, 0, 0, width, height);
      setImageLoaded(true);
    } else {
      image.onload = () => {
        ctx.drawImage(image, 0, 0, width, height);
        setImageLoaded(true);
      };
      image.onerror = () => {
        // Fallback gradient
        const gradient = ctx.createLinearGradient(0, 0, width, height);
        gradient.addColorStop(0, '#D2691E');
        gradient.addColorStop(1, '#CD853F');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, width, height);
        setImageLoaded(true);
      };
    }
  };

  const drawMainCourtBackground = (ctx, canvasWidth, canvasHeight) => {
    if (!mainCourt.enabled) return;

    const margin = 50;
    const courtWidth = mainCourt.width * (canvasWidth - margin * 2) / displaySize.width;
    const courtHeight = mainCourt.length * (canvasHeight - margin * 2) / displaySize.length;
    
    const startX = margin + (canvasWidth - margin * 2 - courtWidth) / 2;
    const startY = margin + (canvasHeight - margin * 2 - courtHeight) / 2;
    
    // Draw court interior color (background only)
    ctx.fillStyle = designOptions.courtInteriorColor;
    ctx.fillRect(startX, startY, courtWidth, courtHeight);
    
    // Draw key area background
    if (mainCourt.showKey) {
      const keyWidth = courtWidth * 0.44;
      const keyHeight = courtHeight * 0.19;
      
      ctx.fillStyle = designOptions.keyColor;
      ctx.fillRect(startX + (courtWidth - keyWidth) / 2, startY, keyWidth, keyHeight);
      
      // Draw key arch background
    //   if (mainCourt.showKeyArch) {
    //     ctx.fillStyle = designOptions.keyArchColor;
    //     ctx.beginPath();
    //     ctx.arc(startX + courtWidth / 2, startY + keyHeight, keyHeight, Math.PI, 0);
    //     ctx.fill();
    //   }
    }
  };

  const drawAllCourtLines = (ctx, canvasWidth, canvasHeight) => {
    if (!mainCourt.enabled) return;

    const margin = 50;
    const courtWidth = mainCourt.width * (canvasWidth - margin * 2) / displaySize.width;
    const courtHeight = mainCourt.length * (canvasHeight - margin * 2) / displaySize.length;
    
    const startX = margin + (canvasWidth - margin * 2 - courtWidth) / 2;
    const startY = margin + (canvasHeight - margin * 2 - courtHeight) / 2;
    
    // Set line properties for visibility on image
    ctx.strokeStyle = designOptions.lineColor;
    ctx.lineWidth = 4; // Thicker lines for better visibility
    ctx.shadowColor = 'rgba(0, 0, 0, 0.5)';
    ctx.shadowBlur = 2;
    
    // Main court border/outline
    ctx.strokeRect(startX, startY, courtWidth, courtHeight);
    
    // Center line
    ctx.beginPath();
    ctx.moveTo(startX, startY + courtHeight / 2);
    ctx.lineTo(startX + courtWidth, startY + courtHeight / 2);
    ctx.stroke();
    
    // Center circle
    if (mainCourt.showCenterCircle) {
      const centerX = startX + courtWidth / 2;
      const centerY = startY + courtHeight / 2;
      ctx.beginPath();
      ctx.arc(centerX, centerY, 60, 0, 2 * Math.PI);
      ctx.stroke();
    }
    
    // Key outline
    if (mainCourt.showKey) {
      const keyWidth = courtWidth * 0.44;
      const keyHeight = courtHeight * 0.19;
      ctx.strokeRect(startX + (courtWidth - keyWidth) / 2, startY, keyWidth, keyHeight);
    }
    
    // 3-point line
    if (mainCourt.showThreePoint) {
      ctx.strokeStyle = designOptions.threePointFillColor;
      ctx.lineWidth = 3;
      
      const threePointRadius = courtHeight * 0.24;
      const basketDistance = courtHeight * 0.15;
      const basketY = startY + basketDistance;
      
      // Left side
      const leftBasketX = startX + courtWidth * 0.15;
      ctx.beginPath();
      ctx.moveTo(startX, basketY - threePointRadius);
      ctx.lineTo(leftBasketX, basketY - threePointRadius);
      ctx.lineTo(leftBasketX, basketY + threePointRadius);
      ctx.lineTo(startX, basketY + threePointRadius);
      ctx.arc(leftBasketX, basketY, threePointRadius, -Math.PI/2, Math.PI/2);
      ctx.stroke();
      
      // Right side
      const rightBasketX = startX + courtWidth * 0.85;
      ctx.beginPath();
      ctx.moveTo(startX + courtWidth, basketY - threePointRadius);
      ctx.lineTo(rightBasketX, basketY - threePointRadius);
      ctx.lineTo(rightBasketX, basketY + threePointRadius);
      ctx.lineTo(startX + courtWidth, basketY + threePointRadius);
      ctx.arc(rightBasketX, basketY, threePointRadius, Math.PI/2, 3*Math.PI/2);
      ctx.stroke();
    }
    
    // Reset shadow
    ctx.shadowColor = 'transparent';
    ctx.shadowBlur = 0;
  };

  const drawElements = (ctx, canvasWidth, canvasHeight) => {
    // Bowling pin markers
    if (elements.bowlingPinMarkers.enabled) {
      const pinCount = elements.bowlingPinMarkers.count;
      const startX = 100;
      const startY = canvasHeight - 100;
      const spacing = 30;
      
      for (let i = 0; i < pinCount; i++) {
        const x = startX + (i % 5) * spacing;
        const y = startY - Math.floor(i / 5) * spacing;
        
        ctx.fillStyle = '#FFFFFF';
        ctx.beginPath();
        ctx.arc(x, y, 8, 0, 2 * Math.PI);
        ctx.fill();
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 2;
        ctx.stroke();
      }
    }
    
    // Baseball bases
    if (elements.baseballBases.enabled) {
      const baseSize = 20;
      const homeX = 150;
      const homeY = canvasHeight - 150;
      
      // Home plate
      ctx.fillStyle = '#FFFFFF';
      ctx.beginPath();
      ctx.moveTo(homeX, homeY);
      ctx.lineTo(homeX + baseSize, homeY);
      ctx.lineTo(homeX + baseSize/2, homeY - baseSize);
      ctx.closePath();
      ctx.fill();
      ctx.strokeStyle = '#000000';
      ctx.lineWidth = 2;
      ctx.stroke();
      
      // Bases
      const bases = [
        { x: homeX + 90, y: homeY - 90 },
        { x: homeX, y: homeY - 180 },
        { x: homeX - 90, y: homeY - 90 }
      ];
      
      bases.forEach(base => {
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(base.x - baseSize/2, base.y - baseSize/2, baseSize, baseSize);
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 2;
        ctx.strokeRect(base.x - baseSize/2, base.y - baseSize/2, baseSize, baseSize);
      });
    }
    
    // Agility ladder
    if (elements.agilityLadder.enabled) {
      const ladderLength = elements.agilityLadder.length * 10;
      const rungWidth = 60;
      const rungHeight = 8;
      const rungSpacing = 40;
      const startX = canvasWidth - 300;
      const startY = canvasHeight - 200;
      
      ctx.fillStyle = '#FF6B6B';
      for (let i = 0; i < ladderLength / rungSpacing; i++) {
        const y = startY + i * rungSpacing;
        ctx.fillRect(startX, y, rungWidth, rungHeight);
      }
    }
    
    // Agility dots
    if (elements.agilityDots.enabled) {
      const dotCount = elements.agilityDots.count;
      const startX = canvasWidth - 400;
      const startY = 200;
      const spacing = 40;
      
      ctx.fillStyle = '#4ECDC4';
      for (let i = 0; i < dotCount; i++) {
        const x = startX + (i % 4) * spacing;
        const y = startY + Math.floor(i / 4) * spacing;
        
        ctx.beginPath();
        ctx.arc(x, y, 15, 0, 2 * Math.PI);
        ctx.fill();
      }
    }
  };

  const drawDesignOptions = (ctx, width, height) => {
    // Draw center court logo
    if (designOptions.centerCourtLogo && mainCourt.enabled) {
      const margin = 50;
      const courtWidth = mainCourt.width * (width - margin * 2) / displaySize.width;
      const courtHeight = mainCourt.length * (height - margin * 2) / displaySize.length;
      const startX = margin + (width - margin * 2 - courtWidth) / 2;
      const startY = margin + (height - margin * 2 - courtHeight) / 2;
      const centerX = startX + courtWidth / 2;
      const centerY = startY + courtHeight / 2;
      
      const logo = new Image();
      logo.src = designOptions.centerCourtLogo;
      
      if (logo.complete) {
        ctx.drawImage(logo, centerX - 40, centerY - 40, 80, 80);
      } else {
        logo.onload = () => {
          ctx.drawImage(logo, centerX - 40, centerY - 40, 80, 80);
        };
      }
    }
    
    // Draw border text
    if (displaySize.type !== 'none') {
      ctx.font = `24px ${designOptions.borderFont}`;
      ctx.fillStyle = designOptions.borderColorTop;
      ctx.textAlign = 'center';
      ctx.fillText('MAIN COURT', width / 2, 40);
      ctx.fillStyle = designOptions.borderColorBottom;
    }
  };

  const drawGridLines = (ctx, width, height) => {
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.2)';
    ctx.lineWidth = 1;
    
    const gridSize = 50;
    
    // Vertical lines
    for (let x = 0; x <= width; x += gridSize) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, height);
      ctx.stroke();
    }
    
    // Horizontal lines
    for (let y = 0; y <= height; y += gridSize) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(width, y);
      ctx.stroke();
    }
  };

  const handleLogoUpload = (file) => {
    if (file) {
      const reader = new FileReader();
      reader.onload = (e) => {
        setDesignOptions(prev => ({
          ...prev,
          centerCourtLogo: e.target.result
        }));
      };
      reader.readAsDataURL(file);
    }
  };

  const handleSave = () => {
    const designData = {
      displaySize,
      designOptions,
      mainCourt,
      additionalCourts,
      elements,
      timestamp: new Date().toISOString()
    };
    localStorage.setItem('gymDesign', JSON.stringify(designData));
    alert('Design saved successfully!');
  };

  const handleDownload = () => {
    if (canvasRef.current) {
      const link = document.createElement('a');
      link.download = `gym-design-${Date.now()}.png`;
      link.href = canvasRef.current.toDataURL();
      link.click();
    }
  };

  const handleReset = () => {
    setShowConfirmModal(true);
  };

  const confirmReset = () => {
    setDisplaySize({
      type: 'high-school',
      width: 100,
      length: 100,
      zoom: 1
    });
    setDesignOptions({
      borderSize: 3,
      borderColorTop: '#000000',
      borderColorBottom: '#000000',
      borderColorLeft: '#000000',
      borderColorRight: '#000000',
      lineColor: '#FFFFFF',
      courtInteriorColor: '#D2691E',
      keyColor: '#CD853F',
    //   keyArchColor: '#A0522D',
      threePointFillColor: '#4169E1',
      centerCourtLogo: null,
      additionalLogos: [],
      gridLines: true,
      borderFont: 'Arial'
    });
    setMainCourt({
      enabled: true,
      width: 84,
      length: 50,
      type: 'basketball',
      showKey: true,
      showKeyArch: true,
      showThreePoint: true,
      showCenterCircle: true
    });
    setAdditionalCourts({
      sideBasketball: { enabled: false, width: 84, length: 50 },
      volleyball: { enabled: false, width: 59, length: 118 },
      badminton: { enabled: false, width: 44, length: 88 },
      pickleball: { enabled: false, width: 44, length: 88 }
    });
    setElements({
      bowlingPinMarkers: { enabled: false, count: 10 },
      baseballBases: { enabled: false },
      numbersAndLetters: { enabled: false, range: '1-24', current: '' },
      agilityLadder: { enabled: false, length: 15 },
      agilityDots: { enabled: false, count: 10 }
    });
    setShowConfirmModal(false);
    setCurrentStep(1);
  };

  useEffect(() => {
    drawCourt();
  }, [drawCourt]);

  // Render current step component
  const renderCurrentStep = () => {
    const stepProps = {
      displaySize,
      setDisplaySize,
      designOptions,
      setDesignOptions,
      mainCourt,
      setMainCourt,
      additionalCourts,
      setAdditionalCourts,
      elements,
      setElements,
      handleLogoUpload,
      nextStep,
      prevStep,
      goToStep
    };

    switch (currentStep) {
      case 1:
        return <Step1DisplaySize {...stepProps} />;
      case 2:
        return <Step2DesignOptions {...stepProps} />;
      case 3:
        return <Step3MainCourt {...stepProps} />;
      case 4:
        return <Step4AdditionalCourts {...stepProps} />;
      case 5:
        return <Step5Elements {...stepProps} />;
      case 6:
        return <Step6Review {...stepProps} />;
      default:
        return <Step1DisplaySize {...stepProps} />;
    }
  };

  return (
    <>
      <HeaderBar />
      <div className={styles.pageWrapper}>
        <div className={styles.pageHeader}>
          <h1>Gym Floor Designer</h1>
          <p>Step {currentStep} of {totalSteps}: Create your perfect gym floor</p>
        </div>
        
        <StepNavigation 
          currentStep={currentStep}
          totalSteps={totalSteps}
          onStepClick={goToStep}
        />
        
        <div className={styles.designerContainer}>
          <div className={styles.stepPanel}>
            {renderCurrentStep()}
          </div>
          
          <div className={styles.canvasContainer}>
            <canvas
              ref={canvasRef}
              width={800}
              height={500}
              className={styles.canvas}
            />
            <div className={styles.canvasInfo}>
              <span>{displaySize.width}ft × {displaySize.length}ft</span>
              <span>{(displaySize.width * displaySize.length).toLocaleString()} sq ft</span>
              <span>Zoom: {displaySize.zoom}x</span>
            </div>
          </div>
        </div>
        
        <div className={styles.stepControls}>
          <button 
            onClick={prevStep} 
            disabled={currentStep === 1}
            className={styles.stepButton}
          >
            Previous
          </button>
          
          <button 
            onClick={handleSave} 
            className={styles.saveButton}
          >
            Save Design
          </button>
          
          <button 
            onClick={handleDownload} 
            className={styles.downloadButton}
          >
            Download PDF
          </button>
          
          <button 
            onClick={handleReset} 
            className={styles.resetButton}
          >
            Start Over
          </button>
          
          <button 
            onClick={nextStep} 
            disabled={currentStep === totalSteps}
            className={styles.stepButton}
          >
            Next
          </button>
        </div>
      </div>
      <Footer />
      
      <ConfirmationModal
        show={showConfirmModal}
        onHide={() => setShowConfirmModal(false)}
        onConfirm={confirmReset}
        title="Reset Design"
        message="Are you sure you want to reset the design? This will clear all your changes."
      />
    </>
  );
};

export default GymDesignerPage;




